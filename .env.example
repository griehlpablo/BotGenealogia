AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Alternativa:
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

HEADLESS=false
SLOW_MODE_MS=250
MIN_DELAY_MS=3000
MAX_DELAY_MS=8000
RESULT_LIMIT=5

# Opcional se o Puppeteer nao encontrar um navegador local.
# Exemplo Windows:
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Opcional. Se ausente, o primeiro login pode ser manual no navegador aberto.
FAMILYSEARCH_EMAIL=
FAMILYSEARCH_PASSWORD=
MYHERITAGE_EMAIL=
MYHERITAGE_PASSWORD=
