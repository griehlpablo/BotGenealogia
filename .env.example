AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest
GEMINI_PDF_MODEL=gemini-1.5-flash-latest
GEMINI_FALLBACK_MODELS=gemini-1.5-flash-latest,gemini-1.5-flash,gemini-pro

# Alternativa:
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

HEADLESS=false
SLOW_MODE_MS=250
MIN_DELAY_MS=3000
MAX_DELAY_MS=8000
RESULT_LIMIT=5
DEBUG_SAVE_HTML=false
PUPPETEER_USER_DATA_DIR=./chrome-profile
CUSTOM_USER_AGENT=
PUPPETEER_EXTRA_ARGS=

# Opcional se o Puppeteer nao encontrar um navegador local.
# Exemplo Windows:
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Para FamilySearch, prefira login manual no navegador aberto pelo bot.
# Nao use VPN/proxy. Se aparecer Error 15, teste primeiro no Chrome normal.
#
# Credenciais sao opcionais. Se ficarem vazias, o login pode ser feito manualmente
# no navegador aberto, e os cookies serao salvos localmente em sessions/.
FAMILYSEARCH_EMAIL=
FAMILYSEARCH_PASSWORD=
MYHERITAGE_EMAIL=
MYHERITAGE_PASSWORD=
FAMILYSEARCH_MODE=manual

WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_LIMIT=10
WEB_SEARCH_MAX_QUERIES=30
WEB_COLLECT_MAX_PAGES=20
WEB_QUEUE_MAX_DEPTH=1
WEB_SEARCH_DELAY_MIN_MS=3000
WEB_SEARCH_DELAY_MAX_MS=9000
WEB_COLLECT_DELAY_MIN_MS=3000
WEB_COLLECT_DELAY_MAX_MS=10000
