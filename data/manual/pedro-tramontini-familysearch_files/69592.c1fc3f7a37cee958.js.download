2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\n\u2551           Chat Websocket Debug Utilities - Help                \u2551\n\u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\n\nAvailable Commands:\n-------------------\n  __CHAT_WS_DEBUG__.simulateTimeout()\n    \u2192 Simulate a real websocket timeout scenario\n    \u2192 Force closes the underlying WebSocket\n    \u2192 Stream will auto-detect and reconnect\n    \u2192 Use this to test the channel requery fix\n\n  __CHAT_WS_DEBUG__.disconnect()\n    \u2192 Manually disconnect the stream client\n    \u2192 Uses Stream's clean closeConnection() method\n    \u2192 Returns a promise\n\n  __CHAT_WS_DEBUG__.reconnect()\n    \u2192 Manually reconnect the stream client\n    \u2192 Uses Stream's openConnection() method\n    \u2192 Returns a promise\n\n  __CHAT_WS_DEBUG__.status()\n    \u2192 Check current connection status (healthy/disconnected/connecting)\n\n  __CHAT_WS_DEBUG__.info()\n    \u2192 Get detailed connection information and failure counts\n\n  __CHAT_WS_DEBUG__.monitorEvents([durationMs])\n    \u2192 Monitor connection-related events for specified duration\n    \u2192 Default: 60000ms (1 minute)\n    \u2192 Useful for debugging event flow\n\n  __CHAT_WS_DEBUG__.help()\n    \u2192 Show this help message\n\nTesting Instructions for QA:\n-----------------------------\n  1. Open a chat channel\n\n  2. Run: __CHAT_WS_DEBUG__.simulateTimeout()\n\n  3. Wait for Stream to automatically reconnect (usually 2-5 seconds)\n\n  4. Send a message in the chat\n     - Message should send successfully\n     - You should receive new messages from others\n\n  5. Verify the channel is working properly after reconnection\n\n  6. Check status: __CHAT_WS_DEBUG__.status()\n     - Should show healthy connection\n\nDiagnosing User-Reported Disconnections:\n-----------------------------------------\n  If a user reports chat disconnected after being idle:\n\n  1. Ask them to open console and run: __CHAT_WS_DEBUG__.info()\n\n  2. Look for:\n     - timeSinceLastEventSeconds > 35-40 = health check failed\n     - consecutiveFailures > 0 = reconnection attempts\n     - totalFailures = lifetime failure count\n\n  3. Check browser console for:\n     - \"connection.changed event fired\" logs\n     - These logs show when/why connection changed\n     - Look for patterns in timing\n\n  Note: Stream health checks expect events every ~35 seconds.\n  If no events arrive, the connection is marked unhealthy and\n  automatic reconnection is triggered.\n")}},console.log("[Chat WS Debug] \ud83d\udee0\ufe0f Websocket debugging tools loaded!"),console.log("[Chat WS Debug] Type __CHAT_WS_DEBUG__.help() for usage information"))}function j(){P=null,"undefined"!==typeof window&&delete window.__CHAT_WS_DEBUG__}var I=n(94451);function R(e){return R="function"==typeof Symbol&&"symbol"==typeof Symbol.iterator?function(e){return typeof e}:function(e){return e&&"function"==typeof Symbol&&e.constructor===Symbol&&e!==Symbol.prototype?"symbol":typeof e},R(e)}function D(e,t){var n=Object.keys(e);if(Object.getOwnPropertySymbols){var r=Object.getOwnPropertySymbols(e);t&&(r=r.filter(function(t){return Object.getOwnPropertyDescriptor(e,t).enumerable})),n.push.apply(n,r)}return n}function M(e){for(var t=1;t<arguments.length;t++){var n=null!=arguments[t]?arguments[t]:{};t%2?