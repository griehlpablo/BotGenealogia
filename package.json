{
  "name": "botgenealogia",
  "version": "1.0.0",
  "description": "Motor local de deducao temporal, scraping genealogico e analise por IA.",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "start:visible": "set HEADLESS=false&& node index.js",
    "start:headless": "set HEADLESS=true&& node index.js",
    "test:familysearch": "set HEADLESS=false&& set AI_PROVIDER=none&& node scripts/test-familysearch.js",
    "urls:familysearch": "node scripts/generate-familysearch-urls.js --source=input",
    "urls:familysearch:pdf": "node scripts/generate-familysearch-urls.js --source=pdf",
    "urls:familysearch:all": "node scripts/generate-familysearch-urls.js --source=all",
    "queries:web": "node scripts/generate-web-queries.js --source=input",
    "queries:web:pdf": "node scripts/generate-web-queries.js --source=pdf",
    "queries:web:all": "node scripts/generate-web-queries.js --source=all",
    "search:web": "node scripts/search-web.js --source=input",
    "search:web:pdf": "node scripts/search-web.js --source=pdf",
    "search:web:all": "node scripts/search-web.js --source=all",
    "test:web-query": "node scripts/test-web-query.js",
    "analyze:manual": "node scripts/analyze-manual.js",
    "doctor": "node -e \"require('./src/logic'); require('./src/ai'); require('./src/scraper'); require('./src/queryGenerator'); require('./src/webSearch'); require('./src/webCollector'); require('./src/sourceClassifier'); require('./src/siteExtractors/google'); require('./src/siteExtractors/bing'); require('./src/siteExtractors/duckduckgo'); console.log('OK')\""
  },
  "keywords": [
    "genealogy",
    "puppeteer",
    "openai",
    "gemini"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.2",
    "openai": "^6.39.0",
    "playwright": "^1.60.0",
    "puppeteer": "^25.0.4",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
